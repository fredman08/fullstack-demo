NODE_ENV=development
PORT=4000

# PostgreSQL — local development (discrete vars)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=fullstack_demo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# PostgreSQL — production (Neon / managed): set DATABASE_URL instead of the
# discrete vars above. SSL is enabled automatically when DATABASE_URL is set.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# CORS — comma-separated origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:4200,http://localhost
